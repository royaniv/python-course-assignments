from image_analysis import detect_composomes


def test_composomes_found():

    composomes, red_regions, non_red_regions = detect_composomes(
        "composition_carpetplot.png"
    )

    assert composomes > 0


def test_red_regions_found():

    composomes, red_regions, non_red_regions = detect_composomes(
        "composition_carpetplot.png"
    )

    assert red_regions > 0


def test_non_red_regions_found():

    composomes, red_regions, non_red_regions = detect_composomes(
        "composition_carpetplot.png"
    )

    assert non_red_regions > 0